<script>
// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
// STATE
// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
let S = {
  timer: { work:25, break:5, lb:15, cycles:4 },
  phase: 'work', cycle: 0,
  left: 0, total: 0, running: false, iv: null,
  blocks: [], tasks: [],
  notion: { token:'', dbId:'', ok:false },
  nPage: null
};

function load() {
  try {
    const d = JSON.parse(localStorage.getItem('df2')||'{}');
    if(d.timer) S.timer=d.timer;
    if(d.blocks) S.blocks=d.blocks;
    if(d.tasks) S.tasks=d.tasks;
    if(d.notion) S.notion=d.notion;
  } catch(e){}
}
function save() {
  try { localStorage.setItem('df2', JSON.stringify({timer:S.timer,blocks:S.blocks,tasks:S.tasks,notion:S.notion})); } catch(e){}
}

load();
boot();

function boot() {
  // Date
  const D=['Sonntag','Montag','Dienstag','Mittwoch','Donnerstag','Freitag','Samstag'];
  const M=['Jan','Feb','MÃ¤r','Apr','Mai','Jun','Jul','Aug','Sep','Okt','Nov','Dez'];
  const n=new Date();
  document.getElementById('hDate').textContent=`${D[n.getDay()]}, ${n.getDate()}. ${M[n.getMonth()]}`;
  // Timer init
  S.left=S.total=S.timer.work*60;
  renderTimer(); renderCycles(); renderCfg();
  renderBlocks(); renderTasks(); renderNotionUI();
  if(S.notion.ok) loadNotionPages();
  if('serviceWorker' in navigator) navigator.serviceWorker.register('sw.js').catch(()=>{});
}

// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
// NAV
// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
function go(name) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  document.getElementById('tab-'+name).classList.add('active');
  if(name==='notion'&&S.notion.ok) loadNotionPages();
}

// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
// TIMER
// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
function toggleTimer() {
  if(S.running) {
    clearInterval(S.iv); S.running=false;
    setPlayIcon(false);
  } else {
    S.running=true; setPlayIcon(true);
    reqNotif();
    S.iv=setInterval(tick,1000);
  }
}
function tick() {
  S.left--;
  if(S.left<=0) { clearInterval(S.iv); S.running=false; phaseDone(); return; }
  renderTimer();
}
function phaseDone() {
  beep();
  if(S.phase==='work') {
    S.cycle++;
    renderCycles();
